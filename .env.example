# IRIS environment template
# Copy this file to `.env` (local only) and fill values as needed.

# Core keys
GOOGLE_API_KEY=
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini

# Docker build/runtime
IRIS_ENABLE_YOLO=1
IRIS_ENABLE_DEEPFACE=0
YOLO_ENABLED=1

# Core scheduler
IRIS_SCHEDULER_POLL_SECONDS=10

# Daily Google Drive sync
IRIS_SYNC_STORE_ID=BLRJAY
IRIS_SYNC_RUN_AT=06:00
IRIS_SYNC_TZ=Asia/Kolkata
IRIS_SYNC_WORKERS=6

# Stage-1 YOLO relevance scheduler
YOLO_RELEVANCE_ENABLED=1
YOLO_RELEVANCE_DAILY_RUN_AT=15:00
YOLO_RELEVANCE_TZ=Asia/Kolkata
YOLO_RELEVANCE_ROOT=/app/data/test_stores
YOLO_RELEVANCE_OUT_ROOT=/app/data/exports/current/stage1_relevance
YOLO_RELEVANCE_STORE_ID=TEST_STORE_D07
YOLO_RELEVANCE_CONF=0.18
YOLO_RELEVANCE_MAX_IMAGES=0
YOLO_RELEVANCE_ALLOW_FALLBACK=0
YOLO_RELEVANCE_GZIP_EXPORTS=1
YOLO_RELEVANCE_DROP_PLAIN_CSV=1

# GPT evaluation scheduler (capped test workloads)
GPT_VISION_ENABLED=0
GPT_DAILY_RUN_AT=02:30
GPT_TZ=Asia/Kolkata
GPT_VISION_MAX_IMAGES=100
GPT_TEST_STORE_ID=TEST_STORE_D07
GPT_TEST_GDRIVE_URL=
GPT_TEST_GROUND_TRUTH=/app/data/exports/gpt_eval/TEST_STORE_D07/ground_truth_template.csv
GPT_TEST_OUTPUT_ROOT=/app/data/exports/gpt_eval
GPT_TEST_DATA_ROOT=/app/data/test_stores
GPT_SAVE_JSON=1
GPT_SKIP_SYNC=0

# On-fly pipeline scheduler (URL-first)
ONFLY_ENABLED=1
ONFLY_STORE_ID=TEST_STORE_D07
ONFLY_SOURCE_URL=
ONFLY_OUT_DIR=/app/data/exports/current/onfly
ONFLY_HOURLY_MINUTES=60
ONFLY_NIGHTLY_RUN_AT=03:00
ONFLY_TZ=Asia/Kolkata
ONFLY_MAX_IMAGES=100
ONFLY_PIPELINE_VERSION=onfly_v1
ONFLY_DETECTOR=yolo
ONFLY_CONF=0.18
ONFLY_ALLOW_DETECTOR_FALLBACK=0

# Phase 1 — React + FastAPI + Celery
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
IRIS_JWT_SECRET=change_me_before_deploy
